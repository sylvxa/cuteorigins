{
  "schemaVersion": 1,
  "id": "cuteorigins",
  "version": "${version}",

  "name": "Sylvie's Origins",
  "description": "An unofficial server-side \"port\" of the Origin's mod, built with Bedrock & vanilla support.",
  "authors": [
      {
        "name": "sylvxa",
        "contact": {
          "email": "me@sylvie.lol",
          "homepage": "https://sylvie.lol"
        }
      }
  ],
  "contact": {
      "repo": "https://github.com/sylvxa/cuteorigins",
      "homepage": "https://modrinth.com/mod/cuteorigins",
      "issues": "https://github.com/sylvxa/cuteorigins/issues",
      "discord": "https://discord.gg/5qzrB98sBA"
  },

  "license": "MIT",
  "icon": "assets/cuteorigins/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": ["lol.sylvie.cuteorigins.CuteOrigins"]
  },

  "mixins": [
    "cuteorigins.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": ">=${minecraft_version}"
  },

  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/class_3222": ["lol/sylvie/cuteorigins/mixininterfaces/Phasable"]
    }
  }
}